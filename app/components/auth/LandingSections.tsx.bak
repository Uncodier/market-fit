        <div className="absolute inset-0 z-0 opacity-70 pointer-events-none flex items-center justify-center">
           <svg className="w-full h-full min-w-[1000px]" viewBox="0 0 1000 1000" preserveAspectRatio="none">
              <defs>
                <linearGradient id="ribbon1" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stopColor="#3b82f6" stopOpacity="0"/>
                  <stop offset="30%" stopColor="#60a5fa" stopOpacity="0.8"/>
                  <stop offset="70%" stopColor="#818cf8" stopOpacity="0.8"/>
                  <stop offset="100%" stopColor="#c084fc" stopOpacity="0"/>
                </linearGradient>
                <linearGradient id="ribbon2" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stopColor="#6366f1" stopOpacity="0"/>
                  <stop offset="40%" stopColor="#8b5cf6" stopOpacity="0.8"/>
                  <stop offset="60%" stopColor="#d946ef" stopOpacity="0.8"/>
                  <stop offset="100%" stopColor="#f43f5e" stopOpacity="0"/>
                </linearGradient>
              </defs>
              
              <g className="animate-wave-slow" style={{ transformOrigin: 'center' }}>
                <path d="M-200,500 C100,300 300,700 600,500 C900,300 1100,700 1400,500" fill="none" stroke="url(#ribbon1)" strokeWidth="8" filter="blur(8px)" opacity="0.6"/>
                <path d="M-200,500 C100,300 300,700 600,500 C900,300 1100,700 1400,500" fill="none" stroke="url(#ribbon1)" strokeWidth="2" opacity="0.9"/>
              </g>
              
              <g className="animate-wave-fast" style={{ transformOrigin: 'center' }}>
                <path d="M-200,550 C150,250 400,800 700,550 C1000,300 1200,800 1400,550" fill="none" stroke="url(#ribbon2)" strokeWidth="6" filter="blur(8px)" opacity="0.5"/>
                <path d="M-200,550 C150,250 400,800 700,550 C1000,300 1200,800 1400,550" fill="none" stroke="url(#ribbon2)" strokeWidth="1.5" opacity="0.8"/>
              </g>
           </svg>
        </div>
        
        {/* Central screen glow */}
        <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-blue-600/10 rounded-full font-sans blur-[120px] mix-blend-screen pointer-events-none"></div>

        <div className="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-12 text-center pt-20">
          <div className="inline-flex items-center rounded-full font-sans border border-white/10 bg-white/5 px-4 py-1.5 text-sm font-medium text-blue-300 backdrop-blur-md mb-8 shadow-[0_0_20px_rgba(59,130,246,0.1)]">
            Omnichannel
          </div>
          
          <h2 className="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tighter mb-8 leading-[1.05]">
            Channel automation <br className="hidden md:block" />
            <span className="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-500 drop-shadow-lg">
              platform
            </span>
          </h2>
          
          <p className="text-lg md:text-2xl text-white/50 max-w-3xl mx-auto font-light leading-relaxed mb-16">
            Connect Email, WhatsApp, LinkedIn, and more. Orchestrate all your multi-channel communications from a single, unified workflow engine.
          </p>

          {/* Central Hub UI */}
          <div className="relative w-full max-w-2xl mx-auto h-[300px] flex items-center justify-center">
            {/* Center Node */}
            <div className="relative z-30 w-24 h-24 rounded-2xl bg-gradient-to-br from-blue-500 to-purple-600 p-0.5 shadow-[0_0_50px_rgba(99,102,241,0.5)]">
              <div className="w-full h-full bg-black/80 backdrop-blur-xl rounded-2xl flex items-center justify-center overflow-hidden">
                 <img src="/images/logo.png" alt="Makinari" className="w-14 h-14 object-contain animate-pulse-slow drop-shadow-[0_0_15px_rgba(255,255,255,0.5)]" />
              </div>
            </div>

            {/* Orbiting Channel Nodes */}
            {[
              { 
                label: 'Email', 
                pos: 'top-0 left-[20%]', 
                color: 'bg-blue-500',
                icon: <svg className="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              },
              { 
                label: 'WhatsApp', 
                pos: 'bottom-10 left-[15%]', 
                color: 'bg-green-500',
                icon: <svg className="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
              },
              { 
                label: 'LinkedIn', 
                pos: 'top-10 right-[20%]', 
                color: 'bg-[#0077b5]',
                icon: <svg className="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              },
              { 
                label: 'SMS', 
                pos: 'bottom-0 right-[25%]', 
                color: 'bg-purple-500',
                icon: <svg className="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
              },
              { 
                label: 'Instagram', 
                pos: 'top-32 left-[5%]', 
                color: 'bg-gradient-to-tr from-[#f09433] via-[#e6683c] to-[#bc1888]',
                icon: <svg className="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              },
            ].map((node, i) => (
              <div key={i} className={`absolute ${node.pos} w-16 h-16 rounded-full font-sans border border-white/10 bg-zinc-900/80 backdrop-blur-md flex items-center justify-center shadow-lg animate-float-medium`} style={{ animationDelay: `${i * 0.5}s` }}>
                <div className={`w-10 h-10 rounded-full font-sans ${node.color} opacity-90 shadow-[0_0_15px_rgba(255,255,255,0.2)] flex items-center justify-center`}>
                  {node.icon}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* 5. SEO and sites specialist system */}
      <section className="relative w-full min-h-screen flex items-center justify-center overflow-hidden border-t border-white/5 bg-[#030504]">
        {/* Topographic Glow Lines Background */}
        <div className="absolute inset-0 z-0 pointer-events-none">
           <svg className="absolute w-full h-full opacity-40" viewBox="0 0 100 100" preserveAspectRatio="none">
              <defs>
                <radialGradient id="seo-glow" cx="50%" cy="100%" r="80%">
                  <stop offset="0%" stopColor="#22c55e" stopOpacity="0.4" />
                  <stop offset="50%" stopColor="#15803d" stopOpacity="0.1" />
                  <stop offset="100%" stopColor="#000000" stopOpacity="0" />
                </radialGradient>
              </defs>
              <rect width="100" height="100" fill="url(#seo-glow)" />
              
              <g stroke="#4ade80" strokeWidth="0.15" fill="none" className="animate-pulse-slow">
                <path d="M 0,100 Q 25,85 50,100 T 100,100" opacity="0.9"/>
                <path d="M 0,92 Q 30,70 60,88 T 100,92" opacity="0.7"/>
                <path d="M 0,84 Q 35,55 70,76 T 100,84" opacity="0.5"/>
                <path d="M 0,76 Q 40,40 80,64 T 100,76" opacity="0.3"/>
                <path d="M 0,68 Q 45,25 90,52 T 100,68" opacity="0.2"/>
                <path d="M 0,60 Q 50,10 100,40" opacity="0.1"/>
              </g>
           </svg>
        </div>

        <div className="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-12 text-center pt-20">
          <div className="inline-flex items-center rounded-full font-sans border border-white/10 bg-white/5 px-4 py-1.5 text-sm font-medium text-green-300 backdrop-blur-md mb-8 shadow-[0_0_20px_rgba(34,197,94,0.1)]">
            Growth Engine
          </div>
          
          <h2 className="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tighter mb-8 leading-[1.05]">
            SEO and sites <br className="hidden md:block" />
            <span className="text-transparent bg-clip-text bg-gradient-to-r from-lime-400 via-green-400 to-emerald-500 drop-shadow-lg">
              specialist system
            </span>
          </h2>
          
          <p className="text-lg md:text-2xl text-white/50 max-w-3xl mx-auto font-light leading-relaxed mb-16">
            Optimize your web presence automatically. Generate SEO-perfected content, track rankings in real-time, and improve your site's performance continuously.
          </p>

          {/* Chart UI Card */}
          <div className="relative mx-auto w-full max-w-4xl rounded-2xl border border-white/10 bg-zinc-900/60 backdrop-blur-2xl p-8 shadow-[0_0_60px_rgba(34,197,94,0.1)] text-left flex gap-8 flex-col md:flex-row">
             <div className="flex-1">
               <div className="text-white/50 text-sm font-semibold uppercase tracking-wider mb-2">Organic Traffic</div>
               <div className="text-5xl font-bold text-white mb-2 flex items-baseline gap-3">
                 24,592 <span className="text-lg text-emerald-400 font-medium bg-emerald-500/10 px-2 py-1 rounded-md">+342%</span>
               </div>
               <div className="h-48 w-full mt-8 relative">
                 {/* Fake SVG Chart */}
                 <svg className="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
                    <defs>
                      <linearGradient id="chart-grad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stopColor="#34d399" stopOpacity="0.5"/>
                        <stop offset="100%" stopColor="#34d399" stopOpacity="0"/>
                      </linearGradient>
                    </defs>
                    <path d="M0,100 L0,80 C20,80 30,50 50,60 C70,70 80,20 100,10 L100,100 Z" fill="url(#chart-grad)" />
                    <path d="M0,80 C20,80 30,50 50,60 C70,70 80,20 100,10" fill="none" stroke="#34d399" strokeWidth="2" className="animate-pulse-slow" />
                 </svg>
               </div>
             </div>
             
             {/* Side Stats */}
             <div className="w-full md:w-64 flex flex-col gap-4">
               {[
                 { label: 'Domain Authority', value: '78', metric: '+12' },
                 { label: 'Keywords Top 10', value: '1,240', metric: '+430' },
                 { label: 'Health Score', value: '98/100', metric: 'Perfect' }
               ].map((stat, i) => (
                 <div key={i} className="bg-white/5 border border-white/5 rounded-xl p-4">
                   <div className="text-xs text-white/40 uppercase font-semibold mb-1">{stat.label}</div>
                   <div className="flex items-end justify-between">
                     <div className="text-xl font-bold text-white">{stat.value}</div>
                     <div className="text-xs text-emerald-400 bg-emerald-500/10 px-1.5 py-0.5 rounded">{stat.metric}</div>
                   </div>
                 </div>
               ))}
             </div>
          </div>
        </div>
      </section>

      {/* Global Unicorn Animations */}
      <style jsx>{`
        .perspective-\\[1200px\\] {
          perspective: 1200px;
        }

        @keyframes spin-super-slow {
          from { transform: rotate(0deg); }
          to { transform: rotate(360deg); }
        }
        .animate-spin-super-slow {
          animation: spin-super-slow 40s linear infinite;
          transform-origin: center;
        }

        @keyframes radar-ping {
          0% { transform: scale(0.1); opacity: 0; border-width: 4px; }
          50% { opacity: 1; border-width: 1px; }
          100% { transform: scale(2); opacity: 0; border-width: 0px; }
        }
        .animate-radar-ping {
          animation: radar-ping 4s cubic-bezier(0, 0.2, 0.8, 1) infinite;
        }

        @keyframes wave-slow {
          0% { transform: translateX(0) scaleY(1); }
          50% { transform: translateX(-3%) scaleY(1.1); }
          100% { transform: translateX(0) scaleY(1); }
        }
        .animate-wave-slow { 
          animation: wave-slow 15s ease-in-out infinite; 
        }

        @keyframes wave-fast {
          0% { transform: translateX(0) scaleY(1); }
          50% { transform: translateX(3%) scaleY(0.9); }
          100% { transform: translateX(0) scaleY(1); }
        }
        .animate-wave-fast { 
          animation: wave-fast 12s ease-in-out infinite; 
        }

        @keyframes pulse-slow {
          0%, 100% { opacity: 1; transform: translateY(0); }
          50% { opacity: 0.8; transform: translateY(2%); }
        }
        .animate-pulse-slow {
          animation: pulse-slow 6s ease-in-out infinite;
        }

        @keyframes float-slow {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(-10px); }
        }
        .animate-float-slow {
          animation: float-slow 4s ease-in-out infinite;
        }

        @keyframes float-medium {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(-15px); }
        }
        .animate-float-medium {
          animation: float-medium 3s ease-in-out infinite;
        }
      `}</style>
    </div>
  )
}